<Window x:Class="HeedNotify.Windows.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="360"
        Height="110"
        ShowActivated="False">
    <Border CornerRadius="10" Background="#FF2B2B2B" Padding="14" BorderBrush="#33000000" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel LastChildFill="True">
                <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="White" FontSize="15"/>
                <Button Content="×"
                        DockPanel.Dock="Right"
                        Width="26" Height="26" Margin="8,0,0,0"
                        Background="#22FFFFFF" Foreground="White"
                        BorderBrush="{x:Null}"
                        Cursor="Hand"
                        Click="OnCloseClick"/>
            </DockPanel>
            <TextBlock Grid.Row="1" Text="{Binding Message}" TextWrapping="Wrap" Foreground="#F0F0F0" Margin="0,8,0,0"/>
        </Grid>
    </Border>
</Window>
